# 数据库
DATABASE_URL=sqlite:///./notifications.db

# 调度器
WORKER_INTERVAL_SECONDS=1
WORKER_BATCH_SIZE=100
WORKER_MAX_CONCURRENCY=32

# 重试
MAX_RETRY_ATTEMPTS=8

# 熔断
BREAKER_FAIL_THRESHOLD=5
BREAKER_OPEN_DURATION_SECONDS=300

# Provider 配置文件路径
PROVIDERS_FILE=./providers.yaml

# 日志
LOG_LEVEL=INFO
LOG_FORMAT=json

# Provider tokens（按 providers.yaml 中声明的 token_env 提供）
CRM_TOKEN=
AD_API_KEY=
